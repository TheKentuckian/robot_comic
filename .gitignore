# User-created personalities (managed by UI)
src/reachy_mini_conversation_app/profiles/user_personalities/

# Git worktrees
.worktrees/

# Comedy session state (runtime artifacts; legacy name kept for back-compat)
.comedy_sessions/
.rickles_sessions/

# Voice prep — large source audio files (source recordings, multi-hundred MB)
profiles/don_rickles/voice_prep/*.wav

# Per-persona reference clips used by local cloning tools (Chatterbox, etc.).
# Archival/copyrighted source — keep local, never commit.
profiles/*/voice_ref.wav

# Per-profile ElevenLabs overrides — keep cloned voice_ids out of public commits.
# The non-local elevenlabs.txt is committed; .local.txt overlays it at runtime.
profiles/*/elevenlabs.local.txt

# Per-persona welcome-gate name WAVs — generated by scripts/build_welcome_assets.py.
# Per-persona; review and `git add -f` selectively when finalizing a persona.
profiles/*/welcome_name.wav

# HuggingFace model cache (faster-whisper, etc.) created by the asset_build tool.
cache/

# Ephemeral benchmark / test output
test_output.txt
.claude/scheduled_tasks.lock
.claude/settings.local.json
